PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# Supabase — get service_role key from your Supabase project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

PUPPETEER_HEADLESS=false
PUPPETEER_SHOW_MOUSE=true

# "true" = manual visible browser login | "false" = headless credential login
AUTH_MANUAL_CONNECT=false

# Indeed agent (scripts/jobhawk_agent.py) — loaded from this .env automatically
# INDEED_HEADLESS=true          # true = no window (login, session check, scrape). false = visible Chrome for manual login
# LINKEDIN_HEADLESS=true
# INDEED_REQUIRE_LOGIN=true     # false = skip login; scrape via homepage search (no account URL)
# INDEED_PROXY_SERVER=http://user:pass@host:port
# Indeed — navigation timeout ms (slow prod networks); default 90000:
# INDEED_NAV_TIMEOUT_MS=90000

# ── Interview reminder emails (~24h before interview_at) ────────────────────────
# Requires migration 006 (interview_* columns + users.email_interview_reminders).
# The API sends reminders once daily at 10:00 (server local time) for interviews tomorrow 07:00–18:00.
#
# --- Gmail (personal Google account) ---
# Your normal Gmail password does NOT work for SMTP — Google returns 535 BadCredentials.
# Use an App Password (only appears after 2-Step Verification is ON):
#   Security → https://myaccount.google.com/signinoptions/two-step-verification
#   Then → https://myaccount.google.com/apppasswords (Mail → Other → e.g. JobHawk)
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM="Your Name <you@gmail.com>"
# SMTP_USER=you@gmail.com
# SMTP_PASS=paste_16_char_app_password_here
#
# --- Generic SMTP ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM="JobHawk <noreply@yourdomain.com>"
# SMTP_USER=
# SMTP_PASS=
# Port 465 usually implies TLS (secure: true); 587 uses STARTTLS by default.

# ── Cover letter generation ─────────────────────────────────────────────────────
# Requires migration 008 (cover_letters table). Downloads as PDF.
#
# openai (default)   — tailored letters via OpenAI (requires OPENAI_API_KEY)
# template           — free rule-based matcher only (set COVER_LETTER_MODE=template)
# COVER_LETTER_MODE=openai
#
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
