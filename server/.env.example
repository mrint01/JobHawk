PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# Set to "false" to watch the browser window while scraping
PUPPETEER_HEADLESS=false

# Red cursor dot in visible browser mode
PUPPETEER_SHOW_MOUSE=false

# Platform auth mode:
# true  -> open visible browser window for manual login (dev-style flow)
# false -> headless credential login + LinkedIn token fallback
AUTH_MANUAL_CONNECT=false
