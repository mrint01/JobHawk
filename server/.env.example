PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# Supabase — get service_role key from your Supabase project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

PUPPETEER_HEADLESS=false
PUPPETEER_SHOW_MOUSE=true

# "true" = manual visible browser login | "false" = headless credential login
AUTH_MANUAL_CONNECT=false

# Indeed (optional) — if prod returns HTTP 403 from hosting IPs, use an HTTP(S) proxy:
# INDEED_PROXY_SERVER=http://user:pass@host:port
# Optional Linux/WebKit user-agent override:
# INDEED_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Safari/605.1.15
# Optional base URL (default https://de.indeed.com):
# INDEED_BASE_URL=https://de.indeed.com
